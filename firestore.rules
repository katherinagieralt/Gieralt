rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Public read collections (portfolio, blog, testimonials for website visitors) ---
    match /portfolioItems/{id} { allow read: if true; allow write: if request.auth != null; }
    match /blogPosts/{id} { allow read: if true; allow write: if request.auth != null; }
    match /testimonials/{id} { allow read: if true; allow write: if request.auth != null; }

    // --- Contact & Leads (public create, admin read/update) ---
    match /contactSubmissions/{id} { allow create: if true; allow read, update, delete: if request.auth != null; }
    match /leadMagnetSignups/{id} { allow create: if true; allow read, delete: if request.auth != null; }

    // --- Client Projects (admin managed) ---
    match /client_projects/{id} { allow read, write: if request.auth != null; }
    match /client_feedback/{id} { allow read, write: if request.auth != null; }

    // --- Scope Proposals: clients can create, admins can read and update ---
    match /scopeProposals/{id} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // --- User Preferences: only the owner can read/write ---
    match /users/{userId}/preferences/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Content Calendar ---
    match /contentCalendar/{id} { allow read, write: if request.auth != null; }

    // --- Fallback: deny everything else ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
