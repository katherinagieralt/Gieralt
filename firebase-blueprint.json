{
  "entities": {
    "ContactSubmission": {
      "title": "Contact Submission",
      "description": "A submission from the contact form.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the person submitting the form."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the person."
        },
        "budget": {
          "type": "string",
          "description": "The budget range selected by the user.",
          "enum": ["< 10k PLN", "10k - 30k PLN", "30k - 50k PLN", "> 50k PLN"]
        },
        "timeline": {
          "type": "string",
          "description": "The timeline selected by the user.",
          "enum": ["ASAP (< 1 mies)", "1-3 mies", "> 3 mies"]
        },
        "message": {
          "type": "string",
          "description": "The message content."
        },
        "status": {
          "type": "string",
          "description": "The current status of the lead.",
          "enum": ["new", "contacted", "completed", "rejected"]
        },
        "notes": {
          "type": "string",
          "description": "Internal notes for the admin."
        },
        "recaptchaToken": {
          "type": "string",
          "description": "The reCAPTCHA v3 token for spam verification."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the submission was created."
        },
        "aiInsights": {
          "type": "object",
          "description": "AI-generated insights for the lead.",
          "properties": {
            "summary": { "type": "string" },
            "score": { "type": "number" },
            "intent": { "type": "string" },
            "sentiment": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "required": ["name", "email", "budget", "timeline", "message", "createdAt"]
    },
    "LeadMagnetSignup": {
      "title": "Lead Magnet Signup",
      "description": "A signup for the lead magnet (e-book/newsletter).",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the subscriber."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the signup was created."
        }
      },
      "required": ["email", "createdAt"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "A blog post article.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the blog post."
        },
        "excerpt": {
          "type": "string",
          "description": "A short summary of the post."
        },
        "content": {
          "type": "string",
          "description": "The HTML content of the post."
        },
        "category": {
          "type": "string",
          "description": "The category of the post."
        },
        "image": {
          "type": "string",
          "description": "URL of the cover image."
        },
        "readTime": {
          "type": "string",
          "description": "Estimated read time (e.g., '5 min')."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of tags for the post."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the post was created."
        }
      },
      "required": ["title", "excerpt", "content", "category", "image", "readTime", "createdAt"]
    },
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "A project in the portfolio.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the project."
        },
        "category": {
          "type": "string",
          "description": "The category (e.g., 'SaaS', 'FinTech')."
        },
        "description": {
          "type": "string",
          "description": "A short description of the project."
        },
        "image": {
          "type": "string",
          "description": "URL of the project image."
        },
        "gallery": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Additional image URLs for the project gallery."
        },
        "link": {
          "type": "string",
          "description": "Link to the live project."
        },
        "caseStudyLink": {
          "type": "string",
          "description": "Link to a detailed case study."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of tags for the project."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the item was created."
        }
      },
      "required": ["title", "category", "description", "image", "link", "createdAt"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "A client review or testimonial.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the client."
        },
        "role": {
          "type": "string",
          "description": "The role or company of the client."
        },
        "content": {
          "type": "string",
          "description": "The testimonial text."
        },
        "avatar": {
          "type": "string",
          "description": "URL of the client's avatar image."
        },
        "rating": {
          "type": "number",
          "description": "Rating from 1 to 5."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the testimonial was created."
        }
      },
      "required": ["name", "role", "content", "rating", "createdAt"]
    },
    "ClientProject": {
      "title": "Client Project",
      "description": "A project managed for a client.",
      "type": "object",
      "properties": {
        "clientEmail": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["in-progress", "completed", "on-hold"] },
        "progress": { "type": "number" },
        "startDate": { "type": "string" },
        "estimatedCompletion": { "type": "string" },
        "currentPhase": { "type": "string" },
        "phases": { "type": "array", "items": { "type": "object" } },
        "links": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientEmail", "name", "status", "progress", "startDate", "estimatedCompletion", "currentPhase", "phases", "createdAt"]
    },
    "ClientFeedback": {
      "title": "Client Feedback",
      "description": "Messages exchanged between admin and client for a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "message": { "type": "string" },
        "sender": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "message", "sender", "createdAt"]
    }
  },
  "firestore": {
    "/contactSubmissions/{submissionId}": {
      "schema": "ContactSubmission",
      "description": "Collection of contact form submissions."
    },
    "/leadMagnetSignups/{signupId}": {
      "schema": "LeadMagnetSignup",
      "description": "Collection of lead magnet signups."
    },
    "/blogPosts/{postId}": {
      "schema": "BlogPost",
      "description": "Collection of blog posts."
    },
    "/portfolioItems/{itemId}": {
      "schema": "PortfolioItem",
      "description": "Collection of portfolio items."
    },
    "/testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Collection of client testimonials."
    },
    "/client_projects/{projectId}": {
      "schema": "ClientProject",
      "description": "Collection of client projects."
    },
    "/client_feedback/{feedbackId}": {
      "schema": "ClientFeedback",
      "description": "Collection of project feedback messages."
    }
  }
}
